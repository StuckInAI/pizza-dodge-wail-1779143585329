 # ──────────────────────────────────────────────────────────
# prompt-the-pizza · environment variables
# Copy this file to .env and fill in your values.
# All VITE_* vars are embedded at build time (public).
# ──────────────────────────────────────────────────────────

# AI Provider: openai | stability | together | mock (default)
# Leave as 'mock' to use the built-in SVG renderer (no key needed).
VITE_AI_PROVIDER=mock

# Your API key for the chosen provider.
# OpenAI   → https://platform.openai.com/api-keys
# Stability → https://platform.stability.ai/account/keys
# Together → https://api.together.xyz/settings/api-keys
VITE_AI_API_KEY=

# Optional: override the default model for your provider.
# openai    default: dall-e-3
# stability default: stable-diffusion-3-large
# together  default: black-forest-labs/FLUX.1-schnell-Free
VITE_AI_MODEL=
